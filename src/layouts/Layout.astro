---
import heroImg from '../assets/img/hero-zicatela.webp';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Nieves Galindo | Zicatela — Nieves Artesanales en Puerto Escondido',
  description = 'Tres generaciones creando nieves de garrafa con frutas naturales. ¡Visítanos frente al mar en Playa Zicatela, Puerto Escondido, Oaxaca!',
  lang = 'es'
} = Astro.props;

const canonicalURL = 'https://nievesgalindo.com';
const ogImage = heroImg.src;

// JSON-LD Structured Data — Local Business
const structuredData = {
  "@context": "https://schema.org",
  "@type": "IceCreamShop",
  "name": "Nieves Galindo",
  "alternateName": "Nieves Galindo Zicatela",
  "description": "Tres generaciones creando nieves de garrafa artesanales con frutas naturales en Playa Zicatela, Puerto Escondido, Oaxaca.",
  "url": canonicalURL,
  "image": `${canonicalURL}${ogImage}`,
  "telephone": "+529541102817",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Playa Zicatela",
    "addressLocality": "Puerto Escondido",
    "addressRegion": "Oaxaca",
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 15.857667,
    "longitude": -97.059112
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
  },
  "sameAs": [
    "https://www.instagram.com",
    "https://www.facebook.com/nieves.galindo.9"
  ],
  "priceRange": "$",
  "servesCuisine": "Ice Cream",
  "currenciesAccepted": "MXN",
  "paymentAccepted": "Cash",
  "areaServed": {
    "@type": "City",
    "name": "Puerto Escondido"
  }
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />

    <!-- SEO Core -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Alternate Language -->
    <link rel="alternate" hreflang="es" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Theme Color -->
    <meta name="theme-color" content="#FEFCF9" />
    <meta name="msapplication-TileColor" content="#FF00FF" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${canonicalURL}${ogImage}`} />
    <meta property="og:image:alt" content="Nieves Galindo — Nieves artesanales frente al mar en Playa Zicatela" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'es' ? 'es_MX' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_MX'} />
    <meta property="og:site_name" content="Nieves Galindo" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonicalURL}${ogImage}`} />
    <meta name="twitter:image:alt" content="Nieves Galindo — Nieves artesanales frente al mar en Playa Zicatela" />

    <!-- Additional SEO -->
    <meta name="author" content="Nieves Galindo" />
    <meta name="geo.region" content="MX-OAX" />
    <meta name="geo.placename" content="Puerto Escondido" />
    <meta name="geo.position" content="15.857667;-97.059112" />
    <meta name="ICBM" content="15.857667, -97.059112" />
    <meta name="keywords" content="nieves galindo, nieves artesanales, nieve de garrafa, Puerto Escondido, Playa Zicatela, helado artesanal, Oaxaca, ice cream, artisanal ice cream, nieves oaxaqueñas" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Structured Data / JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Fonts (preconnect for performance) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
