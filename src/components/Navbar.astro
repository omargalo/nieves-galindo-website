---
import logoImg from '../assets/img/logo.png';
---

<nav class="navbar" id="navbar">
  <a href="#inicio" class="nav-logo-link" aria-label="Inicio">
    <img src={logoImg.src} alt="Nieves Galindo Logo" class="nav-logo" width="60" height="60" />
  </a>

  <ul class="nav-links" id="nav-links">
    <li><a href="#inicio" data-es="Inicio" data-en="Home">Inicio</a></li>
    <li><a href="#historia" data-es="Historia" data-en="Story">Historia</a></li>
    <li><a href="#sabores" data-es="Sabores" data-en="Flavors">Sabores</a></li>
    <li><a href="#ubicacion" data-es="Ubicación" data-en="Location">Ubicación</a></li>
    <li>
      <button class="lang-btn" id="lang-btn" aria-label="Cambiar idioma">
        EN / ES
      </button>
    </li>
  </ul>

  <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.7rem 5%;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: background 0.4s var(--ease-smooth),
                box-shadow 0.4s var(--ease-smooth);
  }

  .navbar.scrolled {
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 4px 30px rgba(157, 249, 255, 0.15),
                0 1px 3px rgba(0, 0, 0, 0.06);
  }

  .nav-logo-link {
    display: flex;
    align-items: center;
    z-index: 10;
  }

  .nav-logo {
    height: 55px;
    width: auto;
    transition: transform 0.3s var(--ease-spring);
    object-fit: contain;
  }

  .nav-logo:hover {
    transform: scale(1.12);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.2rem;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-primary);
    position: relative;
    padding: 0.3rem 0;
    transition: color 0.3s ease;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2.5px;
    background: linear-gradient(90deg, var(--magenta), var(--cyan));
    border-radius: 2px;
    transition: width 0.35s var(--ease-spring);
  }

  .nav-links a:hover {
    color: var(--magenta);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .lang-btn {
    background: linear-gradient(135deg, var(--magenta), #CC00CC);
    color: white;
    padding: 0.45rem 1.2rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    transition: transform 0.25s var(--ease-spring),
                box-shadow 0.25s ease;
  }

  .lang-btn:hover {
    transform: scale(1.06);
    box-shadow: 0 4px 20px var(--magenta-glow);
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    z-index: 1010;
    padding: 4px;
  }

  .hamburger span {
    width: 26px;
    height: 3px;
    background: var(--text-primary);
    border-radius: 3px;
    transition: transform 0.35s var(--ease-spring),
                opacity 0.25s ease,
                background 0.3s ease;
    transform-origin: center;
  }

  .hamburger.active span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
    background: var(--magenta);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger.active span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
    background: var(--magenta);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hamburger {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      flex-direction: column;
      padding: 2rem;
      gap: 1.5rem;
      box-shadow: 0 20px 60px rgba(157, 249, 255, 0.15),
                  0 8px 20px rgba(0, 0, 0, 0.06);
      border-bottom: 2px solid var(--cyan-soft);
    }

    .nav-links.active {
      display: flex;
    }

    .nav-links a {
      font-size: 1.1rem;
    }
  }
</style>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  const handleScroll = () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  };
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Mobile menu
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('nav-links');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    navLinks?.classList.toggle('active');
    const isOpen = hamburger.classList.contains('active');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  // Close mobile menu on link click
  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('active');
      navLinks?.classList.remove('active');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });

  // Language toggle
  const langBtn = document.getElementById('lang-btn');
  let currentLang = 'es';

  langBtn?.addEventListener('click', () => {
    currentLang = currentLang === 'es' ? 'en' : 'es';
    document.documentElement.lang = currentLang;

    // Update all elements with data-es and data-en attributes
    document.querySelectorAll('[data-es][data-en]').forEach(el => {
      const text = el.getAttribute(`data-${currentLang}`);
      if (text) el.textContent = text;
    });

    // Dispatch custom event for other components to listen
    window.dispatchEvent(new CustomEvent('langchange', { detail: { lang: currentLang } }));
  });
</script>
