---

<section class="ubicacion section" id="ubicacion">
  <div class="ubicacion-bg">
    <div class="ubicacion-orb ubicacion-orb--1"></div>
    <div class="ubicacion-orb ubicacion-orb--2"></div>
  </div>

  <div class="section-inner">
    <h2 class="section-title" data-reveal>
      <span data-es="Encuéntranos en" data-en="Find Us at">Encuéntranos en</span>
      <span class="accent" data-es="Zicatela" data-en="Zicatela"> Zicatela</span>
    </h2>
    <p class="section-subtitle" data-reveal
       data-es="Frente al mar, en una de las playas más icónicas del mundo para el surf."
       data-en="By the sea, at one of the world's most iconic surfing beaches.">
      Frente al mar, en una de las playas más icónicas del mundo para el surf.
    </p>

    <div class="ubicacion-card glass-strong" data-reveal="scale">
      <div class="ubicacion-icon-wrap">
        <div class="ubicacion-icon-ring"></div>
        <i class="fa-solid fa-location-dot ubicacion-icon"></i>
      </div>

      <div class="ubicacion-details">
        <h3 data-es="Playa Zicatela" data-en="Zicatela Beach">Playa Zicatela</h3>
        <p data-es="Puerto Escondido, Oaxaca, México" data-en="Puerto Escondido, Oaxaca, Mexico">
          Puerto Escondido, Oaxaca, México
        </p>
      </div>

      <div class="ubicacion-actions">
        <a
          href="https://www.google.com/maps/search/?api=1&query=15.857667,-97.059112"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary ubicacion-btn"
          id="map-btn"
        >
          <i class="fa-solid fa-map-location-dot"></i>
          <span data-es="Abrir en Google Maps" data-en="Open in Google Maps">Abrir en Google Maps</span>
        </a>

        <a
          href="https://wa.me/529541102817"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary ubicacion-btn"
          id="whatsapp-btn"
        >
          <i class="fa-brands fa-whatsapp"></i>
          <span data-es="WhatsApp" data-en="WhatsApp">WhatsApp</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .ubicacion {
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-cool) 100%);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .ubicacion-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .ubicacion-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .ubicacion-orb--1 {
    width: 300px;
    height: 300px;
    background: rgba(157, 249, 255, 0.12);
    top: -50px;
    left: 20%;
    animation: pulse-glow 7s ease-in-out infinite;
  }

  .ubicacion-orb--2 {
    width: 250px;
    height: 250px;
    background: rgba(255, 0, 255, 0.06);
    bottom: -30px;
    right: 15%;
    animation: pulse-glow 7s ease-in-out infinite 3.5s;
  }

  .ubicacion .section-inner {
    position: relative;
    z-index: 1;
  }

  /* Card */
  .ubicacion-card {
    max-width: 560px;
    margin: 0 auto;
    padding: 3rem 2.5rem;
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    transition: transform 0.3s var(--ease-smooth),
                box-shadow 0.3s var(--ease-smooth);
  }

  .ubicacion-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(157, 249, 255, 0.15),
                0 0 40px rgba(255, 0, 255, 0.06);
  }

  /* Icon */
  .ubicacion-icon-wrap {
    position: relative;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ubicacion-icon-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--magenta), var(--cyan));
    animation: rotate-slow 8s linear infinite;
    opacity: 0.2;
  }

  .ubicacion-icon-ring::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: white;
  }

  .ubicacion-icon {
    position: relative;
    z-index: 1;
    font-size: 2rem;
    background: linear-gradient(135deg, var(--magenta), var(--cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Details */
  .ubicacion-details h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--text-primary);
  }

  .ubicacion-details p {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-top: 0.3rem;
  }

  /* Actions */
  .ubicacion-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .ubicacion-btn {
    font-size: 0.95rem;
  }

  /* Responsive */
  @media (max-width: 520px) {
    .ubicacion-card {
      padding: 2rem 1.5rem;
    }

    .ubicacion-actions {
      flex-direction: column;
      width: 100%;
    }

    .ubicacion-btn {
      justify-content: center;
      width: 100%;
    }
  }
</style>
