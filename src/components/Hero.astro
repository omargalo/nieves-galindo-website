---
import heroImg from '../assets/img/hero-zicatela.webp';
---

<section class="hero" id="inicio">
  <div class="hero-bg">
    <img src={heroImg.src} alt="Atardecer en Playa Zicatela, Puerto Escondido" class="hero-bg-img" />
    <div class="hero-overlay"></div>
  </div>

  <!-- Decorative orbs -->
  <div class="hero-orb hero-orb--magenta"></div>
  <div class="hero-orb hero-orb--cyan"></div>

  <!-- Sparkle particles -->
  <div class="hero-sparkles" id="hero-sparkles"></div>

  <div class="hero-content">
    <h1 class="hero-title" id="hero-title">
      <span data-es="Tres Generaciones" data-en="Three Generations">Tres Generaciones</span>
      <br />
      <span class="hero-title-accent" data-es="de Sabor" data-en="of Flavor">de Sabor</span>
    </h1>
    <p class="hero-subtitle" data-es="Desde las montañas de Oaxaca hasta las olas de Puerto Escondido." data-en="From the mountains of Oaxaca to the waves of Puerto Escondido.">
      Desde las montañas de Oaxaca hasta las olas de Puerto Escondido.
    </p>
    <a href="#sabores" class="btn-primary hero-cta">
      <span data-es="Nuestros Sabores" data-en="Our Flavors">Nuestros Sabores</span>
      <i class="fa-solid fa-arrow-down"></i>
    </a>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-dot"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(254, 252, 249, 0.15) 0%,
        rgba(0, 0, 0, 0.20) 30%,
        rgba(0, 0, 0, 0.45) 60%,
        rgba(26, 26, 46, 0.7) 100%
      );
  }

  /* Decorative orbs */
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    z-index: 1;
    animation: pulse-glow 6s ease-in-out infinite;
  }

  .hero-orb--magenta {
    width: 400px;
    height: 400px;
    background: rgba(255, 0, 255, 0.08);
    top: 10%;
    right: -100px;
    animation-delay: 0s;
  }

  .hero-orb--cyan {
    width: 350px;
    height: 350px;
    background: rgba(157, 249, 255, 0.1);
    bottom: 5%;
    left: -80px;
    animation-delay: 3s;
  }

  /* Sparkle container */
  .hero-sparkles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    overflow: hidden;
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 3;
    padding: 0 5%;
    max-width: 900px;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 800;
    color: var(--text-on-image);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.3);
    opacity: 0;
    transform: translateY(30px);
  }

  .hero-title-accent {
    background: linear-gradient(135deg, var(--magenta-soft), var(--cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px rgba(255, 0, 255, 0.3));
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: rgba(255, 255, 255, 0.9);
    font-weight: 300;
    margin-bottom: 2.5rem;
    letter-spacing: 0.02em;
    text-shadow: 0 1px 20px rgba(0, 0, 0, 0.3);
    opacity: 0;
    transform: translateY(20px);
  }

  .hero-cta {
    opacity: 0;
    transform: translateY(20px);
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    width: 28px;
    height: 44px;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: 14px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
    opacity: 0;
    animation: fade-in 1s ease 2.5s forwards;
  }

  .scroll-dot {
    width: 4px;
    height: 8px;
    background: var(--cyan);
    border-radius: 2px;
    animation: bounce-gentle 2s ease-in-out infinite;
    box-shadow: 0 0 8px var(--cyan-glow);
  }

  @keyframes fade-in {
    to { opacity: 0.7; }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-orb--magenta {
      width: 200px;
      height: 200px;
    }

    .hero-orb--cyan {
      width: 180px;
      height: 180px;
    }

    .hero-title {
      font-size: clamp(2rem, 10vw, 3.5rem);
    }

    .scroll-indicator {
      bottom: 1.2rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  // Hero entrance animations
  document.addEventListener('DOMContentLoaded', () => {
    const tl = gsap.timeline({ delay: 0.3 });

    tl.to('.hero-title', {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out'
    })
    .to('.hero-subtitle', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power3.out'
    }, '-=0.5')
    .to('.hero-cta', {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: 'power3.out'
    }, '-=0.3');

    // Create sparkle particles
    const sparkleContainer = document.getElementById('hero-sparkles');
    if (sparkleContainer) {
      for (let i = 0; i < 20; i++) {
        const sparkle = document.createElement('div');
        sparkle.style.cssText = `
          position: absolute;
          width: ${Math.random() * 4 + 2}px;
          height: ${Math.random() * 4 + 2}px;
          border-radius: 50%;
          background: ${Math.random() > 0.5 ? 'var(--magenta)' : 'var(--cyan)'};
          box-shadow: 0 0 ${Math.random() * 8 + 4}px ${Math.random() > 0.5 ? 'var(--magenta-glow)' : 'var(--cyan-glow)'};
          left: ${Math.random() * 100}%;
          top: ${Math.random() * 100}%;
          opacity: 0;
        `;
        sparkleContainer.appendChild(sparkle);

        gsap.to(sparkle, {
          opacity: Math.random() * 0.7 + 0.2,
          duration: Math.random() * 2 + 1,
          repeat: -1,
          yoyo: true,
          delay: Math.random() * 3,
          ease: 'sine.inOut'
        });

        gsap.to(sparkle, {
          y: `${Math.random() * -60 - 20}`,
          x: `${Math.random() * 40 - 20}`,
          duration: Math.random() * 6 + 4,
          repeat: -1,
          yoyo: true,
          delay: Math.random() * 3,
          ease: 'sine.inOut'
        });
      }
    }
  });
</script>
